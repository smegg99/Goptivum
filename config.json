{
  "API": {
    "AllowOrigins": [
      "http://localhost:3000",
      "http://localhost:3001"
    ],
    "MaxRequestSize": 1048576,
    "RateLimitPerMinute": 60
  },
  "Auth": {
    "Login": {
      "Rules": {
        "MinLength": 0,
        "MaxLength": 0,
        "NoSpaces": false
      }
    },
    "Password": {
      "Rules": {
        "MinLength": 0,
        "MaxLength": 0,
        "RequireUppercase": false,
        "RequireLowercase": false,
        "RequireNumbers": false,
        "RequireSpecialChars": false
      }
    },
    "PasswordHashing": {
      "Time": 3,
      "Memory": 65536,
      "Threads": 1,
      "KeyLen": 32
    },
    "JWT": {
      "AccessTokenExpiry": 900,
      "RefreshTokenExpiry": 604800
    }
  }
}